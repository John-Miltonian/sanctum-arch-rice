# Sanctum OS - Additions to .zshrc
# Add these lines to your ~/.zshrc

# Cross prompt
source ~/.config/zsh/cross-prompt.zsh

# Christian aliases
source ~/.config/zsh/aliases

# Add local bin to PATH
export PATH="$HOME/.local/bin:$PATH"

