// Sanctum OS - Niri Configuration
// Dark Christian themed tiling window manager

input {
    keyboard {
        xkb {
            layout "us"
        }
    }
    touchpad {
        tap
        natural-scroll
    }
}

output "*" {
    // Dark wallpaper - Caravaggio/Tenebrism style
    background-path "/home/josh/.config/wallpapers/sanctum-dark.jpg"
}

// Dark color scheme with gold accents
spawn-at-startup "swaybg" "-m" "fill" "-i" "/home/josh/.config/wallpapers/sanctum-dark.jpg"
spawn-at-startup "waybar"
spawn-at-startup "kitty" "--session" "/home/josh/.config/kitty/session.conf"

// Idle management
spawn-at-startup "swayidle" "-w" "timeout" "600" "swaylock" "-f" "-i" "/home/josh/.config/wallpapers/sanctum-dark.jpg"

// Clipboard
spawn-at-startup "wl-paste" "--watch" "cliphist" "store"

layout {
    gaps 8
    center-focused-column "never"
    
    // Focus follows mouse
    focus-follows-mouse
    
    // Prevent windows from stealing focus
    automatically-unhide-cursor
}

// Window rules for transparency
window-rule {
    // All terminals get transparency
    match app-id="kitty"
    opacity 0.95
    border-color "#c9a227"  // Gold border
}

window-rule {
    match app-id="bibletime"
    opacity 0.98
}

window-rule {
    match app-id="xiphos"
    opacity 0.98
}

window-rule {
    match app-id="firefox"
    opacity 0.97
}

window-rule {
    match app-id="thunar"
    opacity 0.95
}

window-rule {
    match app-id="pavucontrol"
    opacity 0.90
}

window-rule {
    // Floating windows
    match title="Save File"
    match title="Open File"
    match title="Confirm"
    opacity 0.95
    open-floating
}

// Binds
binds {
    // Basics
    Super+Return spawn "kitty"
    Super+Q close-window
    
    // Launcher
    Super+Space spawn "wofi --show drun --style ~/.config/wofi/style.css"
    Super+Shift+Space spawn "wofi --show run --style ~/.config/wofi/style.css"
    
    // Christian tools quick launch
    Super+B spawn "kitty -e bible-cli"
    Super+Shift+B spawn "bibletime"
    Super+V spawn "kitty -e daily-verse"
    Super+K spawn "kitty -e kjv"
    
    // Window management
    Super+Left focus-column-left
    Super+Right focus-column-right
    Super+Up focus-window-up
    Super+Down focus-window-down
    
    Super+Shift+Left move-column-left
    Super+Shift+Right move-column-right
    Super+Shift+Up move-window-up
    Super+Shift+Down move-window-down
    
    // Workspaces (named after Christian concepts)
    Super+1 focus-workspace "Sanctum"      // Main workspace
    Super+2 focus-workspace "Scripture"    // Bible/study
    Super+3 focus-workspace "Communion"     // Communication
    Super+4 focus-workspace "Labor"        // Work/dev
    Super+5 focus-workspace "Reflection"  // Media/entertainment
    Super+6 focus-workspace "Rest"          // Extra
    Super+7 focus-workspace "Prayer"        // Meditation/prayer apps
    Super+8 focus-workspace "Study"        // Learning
    Super+9 focus-workspace "Service"      // System/tasks
    Super+0 focus-workspace "Glory"        // Special
    
    Super+Shift+1 move-column-to-workspace "Sanctum"
    Super+Shift+2 move-column-to-workspace "Scripture"
    Super+Shift+3 move-column-to-workspace "Communion"
    Super+Shift+4 move-column-to-workspace "Labor"
    Super+Shift+5 move-column-to-workspace "Reflection"
    Super+Shift+6 move-column-to-workspace "Rest"
    Super+Shift+7 move-column-to-workspace "Prayer"
    Super+Shift+8 move-column-to-workspace "Study"
    Super+Shift+9 move-column-to-workspace "Service"
    Super+Shift+0 move-column-to-workspace "Glory"
    
    // Overview (Exposé)
    Super+Tab toggle-overview
    
    // Window states
    Super+F toggle-fullscreen
    Super+Shift+F toggle-windowed
    
    // Monitor focus
    Super+Period focus-monitor-next
    Super+Comma focus-monitor-previous
    
    Super+Shift+Period move-column-to-monitor-next
    Super+Shift+Comma move-column-to-monitor-previous
    
    // Scrolling
    Super+WheelScrollDown focus-column-right
    Super+WheelScrollUp focus-column-left
    Super+Shift+WheelScrollDown move-column-right
    Super+Shift+WheelScrollUp move-column-left
    
    // Consumes
    Super+Minus consume-window-into-column
    Super+Plus expel-window-from-column
    
    // Column width
    Super+R switch-preset-column-width
    Super+Shift+R switch-preset-window-height
    
    // Screenshot
    Super+Print spawn "grim -g \"$(slurp)\" - | wl-copy"
    Super+Shift+Print spawn "grim -g \"$(slurp)\" ~/Pictures/Screenshots/$(date +%Y%m%d_%H%M%S).png"
    
    // Lock
    Super+L spawn "swaylock -f -i /home/josh/.config/wallpapers/sanctum-dark.jpg --clock --effect-blur 7x5"
    
    // Exit
    Super+Shift+E quit
    Super+Shift+Backspace spawn "niri msg action power-off-monitors"
}

// Environment
environment {
    QT_QPA_PLATFORM "wayland"
    SDL_VIDEODRIVER "wayland"
    _JAVA_AWT_WM_NONREPARENTING "1"
    MOZ_ENABLE_WAYLAND "1"
}

// Debug
prefer-no-csd
