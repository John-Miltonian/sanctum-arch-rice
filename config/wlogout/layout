[
    {
        "label" : "lock",
        "action" : "swaylock -f -i ~/.config/wallpapers/sanctum-dark.jpg --clock --effect-blur 7x5",
        "text" : "✠ Lock",
        "keybind" : "l"
    },
    {
        "label" : "logout",
        "action" : "niri msg action quit",
        "text" : "✞ Logout",
        "keybind" : "e"
    },
    {
        "label" : "suspend",
        "action" : "systemctl suspend",
        "text" : "☾ Sleep",
        "keybind" : "u"
    },
    {
        "label" : "shutdown",
        "action" : "systemctl poweroff",
        "text" : "✚ Power Off",
        "keybind" : "s"
    },
    {
        "label" : "reboot",
        "action" : "systemctl reboot",
        "text" : "↻ Reboot",
        "keybind" : "r"
    }
]
